# Auto detect text files and normalize line endings to LF
* text=auto

# Explicitly declare text files to use LF
*.md text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.ini text eol=lf
*.txt text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files
*.o binary
*.a binary
*.lib binary
*.dll binary
*.exe binary
*.so binary
